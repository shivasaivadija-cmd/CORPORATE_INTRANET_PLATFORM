# ============================================================
# CORPORATE INTRANET PLATFORM - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ============================================================

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://intranet:intranet_secret@localhost:5432/intranet_db
POSTGRES_USER=intranet
POSTGRES_PASSWORD=intranet_secret
POSTGRES_DB=intranet_db

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379

# ─── Authentication ──────────────────────────────────────────
# IMPORTANT: Change these in production! Use: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
REFRESH_TOKEN_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ─── AI (Gemini) ─────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIzaSyAFntuVi-sYS1eS-JjVHsCNH9rAfJwlPpg"
GEMINI_MODEL=gemini-1.5-pro
GEMINI_EMBEDDING_MODEL=text-embedding-004
ENABLE_AI_MODERATION=false
ENABLE_AI_SUMMARY=true
ENABLE_SEMANTIC_SEARCH=true

# ─── Storage (AWS S3 / Cloudflare R2) ────────────────────────
STORAGE_PROVIDER=s3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET_NAME=intranet-uploads
CDN_URL=https://your-cdn-domain.com
MAX_FILE_SIZE_MB=50

# ─── Frontend (Next.js) ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXT_PUBLIC_CDN_URL=

# ─── Mobile (Expo) ───────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:4000/api/v1
EXPO_PUBLIC_WS_URL=http://localhost:4000
